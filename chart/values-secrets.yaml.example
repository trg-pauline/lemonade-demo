# Example secrets file for MaaS configuration
# Copy this file to values-secrets.yaml and fill in your actual values
# IMPORTANT: values-secrets.yaml is gitignored and should never be committed

# MaaS (Model as a Service) configuration
# ALL fields are REQUIRED when maas.enabled=true
maas:
  # The MaaS endpoint URL (hostname only, without https:// prefix or trailing /)
  # Example: "api.openai.com" or "your-litellm-instance.example.com"
  endpoint: "your-maas-endpoint-here"

  # The API key for your MaaS endpoint
  # Example: "sk-..." for OpenAI-compatible endpoints
  api_key: "your-api-key-here"

  # The model name to use
  # Example: "gpt-4", "gpt-3.5-turbo", or your custom model name
  # IMPORTANT: Ensure your API key has access to this model
  model: "your-model-name-here"
